---
import { SITE } from "@/config/site";

const phone = SITE.whatsapp;
const message = 'Hola, deseo información sobre sus servicios de transporte.'

const whatsappUrl = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`
---

<a href={whatsappUrl} target='_blank' rel='noopener noreferrer' aria-label='WhatsApp' class='group fixed bottom-6 right-6 z-[9999]'>
	<div class='absolute right-16 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-all duration-300 pointer-events-none'>
		<div class='bg-[#161616] text-white text-sm px-4 py-2 rounded-lg whitespace-nowrap shadow-xl border border-white/10'>¿Necesitas ayuda?</div>
	</div>

	<div class='relative flex h-16 w-16 items-center justify-center rounded-full bg-[#25D366]
           shadow-[0_10px_35px_rgba(37,211,102,.45)]
           transition-all duration-300
           hover:scale-110 hover:rotate-6'>
		<!-- Efecto Pulse -->
		<span class='absolute inline-flex h-full w-full rounded-full bg-[#25D366] opacity-40 animate-ping'> </span>

		<!-- Icono -->
		<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-8 w-8 text-white' fill='currentColor'>
			<path
				d='M20.52 3.48A11.86 11.86 0 0012.04 0C5.43 0 .05 5.38.05 11.99c0 2.11.55 4.18 1.59 6.01L0 24l6.17-1.62a11.95 11.95 0 005.87 1.5h.01c6.61 0 11.99-5.38 11.99-11.99 0-3.2-1.25-6.2-3.52-8.41zm-8.48 18.4a9.9 9.9 0 01-5.05-1.39l-.36-.21-3.66.96.98-3.57-.23-.37a9.9 9.9 0 01-1.52-5.31c0-5.46 4.44-9.9 9.9-9.9 2.64 0 5.13 1.03 7 2.9a9.83 9.83 0 012.9 7c0 5.46-4.44 9.89-9.9 9.89zm5.43-7.43c-.3-.15-1.77-.87-2.05-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.95 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.41-1.46-.89-.79-1.49-1.76-1.67-2.06-.17-.3-.02-.47.13-.62.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.21-.24-.58-.49-.5-.67-.5h-.57c-.2 0-.52.08-.79.38-.27.3-1.04 1.01-1.04 2.46 0 1.45 1.06 2.85 1.21 3.05.15.2 2.08 3.18 5.04 4.46.7.3 1.24.48 1.67.61.7.22 1.34.19 1.85.12.56-.08 1.77-.72 2.02-1.41.25-.69.25-1.29.17-1.42-.07-.12-.27-.2-.57-.35z'
			></path>
		</svg>
	</div>
</a>
