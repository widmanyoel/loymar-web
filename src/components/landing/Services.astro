<section id="services" class="py-24 max-w-7xl mx-auto px-6">
  <div class="text-center mb-16">
    <span class="text-[#008080] font-bold text-sm tracking-widest uppercase mb-4 block">Nuestras Soluciones</span>
    <h2 class="font-serif text-5xl text-white">Servicios Especializados</h2>
    <div class="w-24 h-1 bg-[#f4c025] mx-auto mt-6"></div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {
      services.map((service) => (
        <div class="group bg-[#161616] rounded-xl overflow-hidden border border-white/5 hover:border-[#f4c025]/30 transition-all duration-500">
          <div class="h-64 overflow-hidden relative">
            <div class="absolute inset-0 bg-[#f4c025]/10 group-hover:bg-transparent transition-colors z-10"></div>
            <img
              src={service.img}
              alt={service.title}
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
            />
          </div>
          <div class="p-8">
            <span class="material-symbols-outlined text-[#f4c025] text-4xl mb-4">{service.icon}</span>
            <h3 class="text-xl font-bold text-white mb-2">{service.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{service.desc}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>