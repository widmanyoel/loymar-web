<section class="max-w-7xl mx-auto px-6 -mt-0 relative z-30">
  <div class="bg-[#161616] border border-[#f4c025]/20 rounded-xl p-8 shadow-2xl">
    <div class="flex items-center gap-2 mb-6">
      <span class="material-symbols-outlined text-[#f4c025]">calendar_month</span>
      <h3 class="font-serif text-2xl text-white">Reserva tu Viaje</h3>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4">
      <div class="space-y-2">
        <label class="text-[10px] uppercase tracking-tighter text-slate-400 font-bold">Servicio</label>
        <select class="w-full bg-[#0a0a0a] border border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-[#f4c025] focus:ring-[#f4c025] text-white">
          <option>Transporte Personal</option>
          <option>Traslado Aeropuerto</option>
          <option>VIP Ejecutivo</option>
        </select>
      </div>
      <div class="space-y-2">
        <label class="text-[10px] uppercase tracking-tighter text-slate-400 font-bold">Pasajeros</label>
        <input type="number" min="1" value="1" class="w-full bg-[#0a0a0a] border border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-[#f4c025] text-white" />
      </div>
      <div class="space-y-2">
        <label class="text-[10px] uppercase tracking-tighter text-slate-400 font-bold">Origen</label>
        <input type="text" placeholder="Punto de recogida" class="w-full bg-[#0a0a0a] border border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-[#f4c025] text-white" />
      </div>
      <div class="space-y-2">
        <label class="text-[10px] uppercase tracking-tighter text-slate-400 font-bold">Destino</label>
        <input type="text" placeholder="¿A dónde vas?" class="w-full bg-[#0a0a0a] border border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-[#f4c025] text-white" />
      </div>
      <div class="space-y-2">
        <label class="text-[10px] uppercase tracking-tighter text-slate-400 font-bold">Fecha</label>
        <input type="date" class="w-full bg-[#0a0a0a] border border-slate-700 rounded-lg text-sm px-3 py-2.5 focus:border-[#f4c025] text-white" />
      </div>
      <div class="flex items-end">
        <button class="w-full bg-[#f4c025] text-[#0a0a0a] font-bold py-2.5 rounded-lg hover:brightness-110 transition-all uppercase text-xs tracking-wider">
          Cotizar
        </button>
      </div>
    </div>
  </div>
</section>