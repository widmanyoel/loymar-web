<section id="fleet" class="py-24 bg-[#0a0a0a]/50 border-y border-white/5">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div>
        <span class="text-[#f4c025] font-bold text-sm tracking-widest uppercase mb-4 block">Nuestra Flota</span>
        <h2 class="font-serif text-5xl text-white">Elige tu Estilo de Viaje</h2>
      </div>
      <p class="max-w-md text-slate-400">Contamos con vehículos de última generación, equipados con climatización y asientos de cuero.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        fleet.map((item) => (
          <div class="bg-[#161616] p-4 rounded-xl border border-white/5 group">
            <div class="aspect-video rounded-lg overflow-hidden mb-6">
              <img
                src={item.img}
                alt={item.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <h4 class="text-white font-bold text-lg mb-1">{item.name}</h4>
            <div class="flex items-center gap-4 text-xs text-slate-400">
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-[16px]">person</span> {item.passengers} Pasajeros
              </span>
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-[16px]">luggage</span> {item.luggage}
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>